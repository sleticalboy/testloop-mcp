package sample

import (
	"testing"
)

// TestAddCoversGap 测试 Add
// coverage task: go-task-1 | lines 4-4 | 断言未覆盖分支的返回值或副作用
func TestAddCoversGap(t *testing.T) {
	type testCase struct {
		name string
		skip bool
		a    int
		b    int
		ret0 int
	}

	tests := []testCase{
		{
			name: "coverage branch gap",
			skip: false,
			a:    1,
			b:    2,
			ret0: 1 + 2,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if tt.skip {
				t.Skip("TODO: fill in meaningful test inputs and expected values")
			}
			got := Add(tt.a, tt.b)
			if got != tt.ret0 {
				t.Errorf("got %v, want %v", got, tt.ret0)
			}
		})
	}
}
