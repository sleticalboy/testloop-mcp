{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sleticalboy/testloop-mcp/main/docs/fixtures/agent-decision-client-ci-template-install-summary.schema.json",
  "title": "testloop Agent decision client CI template install summary",
  "description": "Machine-readable contract for scripts/showcase-agent-decision-client-ci-template-install.sh --json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "installer_path",
    "installer_url",
    "client_dir",
    "workflow_path",
    "helper_dir",
    "helper_ref",
    "summary_json",
    "response_json",
    "response_validation_json",
    "fixture_count",
    "decisions",
    "failures",
    "contract_exit_code",
    "validator_exit_code",
    "response_validator_exit_code"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "installer_path": {
      "type": "string",
      "minLength": 1
    },
    "installer_url": {
      "type": "string"
    },
    "client_dir": {
      "type": "string",
      "minLength": 1
    },
    "workflow_path": {
      "type": "string",
      "minLength": 1
    },
    "helper_dir": {
      "type": "string",
      "minLength": 1
    },
    "helper_ref": {
      "type": "string",
      "minLength": 1
    },
    "summary_json": {
      "type": "string",
      "minLength": 1
    },
    "response_json": {
      "type": "string",
      "minLength": 1
    },
    "response_validation_json": {
      "type": "string",
      "minLength": 1
    },
    "fixture_count": {
      "type": "integer",
      "minimum": 0
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failures": {
      "type": "array"
    },
    "contract_exit_code": {
      "type": "integer",
      "minimum": 0
    },
    "validator_exit_code": {
      "type": "integer",
      "minimum": 0
    },
    "response_validator_exit_code": {
      "type": "integer",
      "minimum": 0
    }
  }
}
