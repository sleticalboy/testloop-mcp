{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sleticalboy/testloop-mcp/main/docs/fixtures/agent-decision-client-ci-summary.schema.json",
  "title": "testloop Agent decision client CI summary",
  "description": "Machine-readable contract for scripts/showcase-agent-decision-client-ci.sh --json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "client_dir",
    "fixture_dir",
    "result_json",
    "result_schema",
    "fixture_count",
    "decisions",
    "failures",
    "validator_exit_code"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "client_dir": {
      "type": "string",
      "minLength": 1
    },
    "fixture_dir": {
      "type": "string",
      "minLength": 1
    },
    "result_json": {
      "type": "string",
      "minLength": 1
    },
    "result_schema": {
      "type": "string",
      "minLength": 1
    },
    "fixture_count": {
      "type": "integer",
      "minimum": 0
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validator_exit_code": {
      "type": "integer",
      "minimum": 0
    }
  }
}
